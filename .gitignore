.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
__pycache__/
ignore_folder/

# Build output
dist/*
!dist/service-worker.js
!dist/styles.css
!dist/favicon.svg
!dist/favicon.ico
!dist/manifest.json

# Data directories
data/boundaries/
data/caches/
data/rugby/league_data/
data/rugby/team_addresses/
# Ignore everything in distance_cache except the global routed cache below.
# (Glob form, not directory form, so we can re-include specific files.)
data/rugby/distance_cache/*
!data/rugby/distance_cache/routed/
data/rugby/distance_cache/routed/*
data/rugby/standings_cache/
data/rugby/*.md

# Routed (road) distance matrix is global and stable across seasons --
# commit it so the build works without requiring everyone to run OSRM locally.
!data/rugby/distance_cache/routed/all.npz
!data/rugby/distance_cache/routed/all.json
data/football/*
data/scotland/*

.cursor/*

scotland/*
!scotland/__init__.py
!scotland/*.py
football/*
!football/__init__.py
!football/*.py
